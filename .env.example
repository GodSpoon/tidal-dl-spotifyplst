# Spotify App credentials
# Create an app at https://developer.spotify.com/dashboard
# Add this EXACT redirect URI to the app's "Redirect URIs":
#   http://127.0.0.1:8888/callback
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

# Tidal OAuth app credentials (optional - tidal-dl uses its own keys by default)
# Only override if you want to use your own keys inside tidal-dl
# TIDAL_CLIENT_ID=your_tidal_client_id
# TIDAL_CLIENT_SECRET=your_tidal_client_secret

# Where to write outputs
OUTPUT_DIR=./output
# Where tiddl should save downloaded files
TIDAL_DOWNLOAD_DIR=./tiddl_downloads
# Tidal audio quality: max, high, normal, low
TIDAL_QUALITY=max

# Library organisation (optional)
# Destination directory for organized music (e.g., Navidrome/Plexamp library)
# LIBRARY_DIR=/Volumes/media/Audio/Music
# Path template for file organisation:
# LIBRARY_SCHEMA={artist}/{album}/{track_num:02d} - {title}.{ext}
#
# Post-processing toggles (optional)
# TRANSCODE_TO_MP3=true
# DELETE_SOURCE_AFTER_TRANSCODE=false
# Downloader backend selection (optional)
# Choose: tiddl | tidarr | qobuz | squidwtf | both | all
# DOWNLOADER=tiddl
# TIDARR_URL=http://localhost:8484
# TIDARR_API_KEY=your_tidarr_api_key

# Multi-source support (optional)
# Comma-separated list of sources to enable: tidal, qobuz
# SOURCES=tidal
# Qobuz credentials (required when qobuz is in SOURCES)
# QOBUZ_APP_ID=
# QOBUZ_AUTH_TOKEN=